# VPS Panel - Environment Configuration
# Copy to .env: cp .env.example .env

# Server ports
PORT=3000
SSL_PORT=3443

# JWT Secret (change this! use: openssl rand -hex 32)
JWT_SECRET=change-me-to-something-random-and-long

# Environment
NODE_ENV=production

# Data directory (optional, defaults to ../data relative to backend/)
# DATA_DIR=/opt/vps-panel-data
