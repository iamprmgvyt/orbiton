PORT=3000
SSL_PORT=3443
# MANDATORY: Must be set! Generate with: openssl rand -hex 32
JWT_SECRET=generate_with_openssl_rand_hex_32
NODE_ENV=production
DISABLE_SSL=true
DAEMON_URL=http://localhost:9900
# MANDATORY: Must match DAEMON_TOKEN in daemon/.env. Generate with: openssl rand -hex 32
DAEMON_TOKEN=generate_with_openssl_rand_hex_32

# (Optional) Supabase database URL connection string to store public reviews/feedbacks.
# If left empty, Orbiton Panel will automatically fallback to storing reviews in local SQLite.
SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.ylrvrgblyakssqfjkchg.supabase.co:5432/postgres

