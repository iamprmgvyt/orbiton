# VPS Panel - Environment Configuration
# Copy to .env: cp .env.example .env

# Server ports (default: HTTP 80, HTTPS 443)
PORT=80
SSL_PORT=443

# JWT Secret (change this! use: openssl rand -hex 32)
JWT_SECRET=change-me-to-something-random-and-long

# Environment
NODE_ENV=production

# Disable SSL redirects and only use HTTP port 80
# Set to 'true' to completely disable HTTPS even if certs are present.
DISABLE_SSL=false

# Data directory (optional, defaults to database path)
# DATA_DIR=/opt/orbiton-data
