# 🪐 Orbiton VPS Terminal Telegram Bot Configuration

# 1. Telegram Bot Token (Create one by messaging @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ

# 2. Authorized Telegram User ID (Only this account can run commands)
# Message @userinfobot or @raw_data_bot on Telegram to find your User ID
AUTHORIZED_USER_ID=your-telegram-numeric-id

# 3. Target VPS Default User
VPS_USER=ubuntu
