# 🪐 Orbiton VPS Terminal Discord Bot Configuration

# 1. Discord Bot Token (Create one from the Discord Developer Portal: https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=your-discord-bot-token

# 2. Authorized Discord User ID (Only this account can run commands)
# Enable Developer Mode in Discord, right-click your user name, and select "Copy User ID"
AUTHORIZED_USER_ID=1262304052361035857

# 3. Execution Configuration
# Set to true to execute commands with sudo/root privileges, or false to run as standard user
RUN_AS_ROOT=true
